DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,.localhost,.lvh.me,.localtest.me

POSTGRES_DB=warehouse_saas
POSTGRES_USER=warehouse_user
POSTGRES_PASSWORD=warehouse_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgres://warehouse_user:warehouse_password@postgres:5432/warehouse_saas

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Frontend / Next.js BFF
BACKEND_INTERNAL_ORIGIN=http://backend:8000
TENANT_BACKEND_HOST_SUFFIX=lvh.me:8000
# Shared local frontend cookies across workspace subdomains.
# Browse via http://tenant.lvh.me:3000 or let the app redirect from *.localhost.
FRONTEND_COOKIE_DOMAIN=lvh.me
FRONTEND_BASE_DOMAIN=lvh.me
NEXT_PUBLIC_FRONTEND_BASE_DOMAIN=lvh.me
NEXT_PUBLIC_APP_NAME=Multi-Tenant WMS
